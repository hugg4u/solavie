NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=solavie
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_CACHE_URL=redis://localhost:6379/0
REDIS_QUEUE_URL=redis://localhost:6380/0

# Security
JWT_ACCESS_SECRET=solavie_access_secret_example_please_change
JWT_SETUP_SECRET=solavie_setup_secret_example_please_change
AES_ENCRYPTION_KEY=solavie_encryption_key_32_bytes_length!!
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800
COOKIE_SECRET=solavie_cookie_secret_example_please_change
PERMISSION_CACHE_TTL=3600
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000

