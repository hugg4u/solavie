JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_SECRET=super_secret_refresh_key
JWT_REFRESH_EXPIRES_IN=604800
JWT_SETUP_SECRET=your_jwt_setup_secret_super_long_key_solavie
JWT_SETUP_EXPIRES_IN=15m
ACTIVATION_TOKEN_TTL_SEC=172800
IDEMPOTENCY_TTL_SEC=86400
AES_ENCRYPTION_KEY=32_bytes_long_secret_key_for_aes_256_gcm!

# --- SUPER ADMIN CONFIGURATION ---
